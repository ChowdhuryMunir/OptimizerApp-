<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark Material theme — minimal overrides to keep app size small -->
    <style name="Theme.PerfOptimizer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/surface</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/surface</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <!-- Disable window animations on low-end devices — saves CPU -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
